{
  "$schema": "./.dt-app/app.config.schema.json",
  "environmentUrl": "https://jeq40225.apps.dynatrace.com/",
  "app": {
    "name": "Executive Overview",
    "version": "0.9.0",
    "description": "Executive health overview for Web Apps, Infra, Services, DBs",
    "id": "my.executive.overview",
    "scopes": [
      { "name": "storage:metrics:read", "comment": "Read metrics from Grail" },
      { "name": "storage:events:read", "comment": "Read events" },
      { "name": "storage:spans:read", "comment": "Read distributed traces" },
      { "name": "storage:entities:read", "comment": "Read entity data" },
      { "name": "storage:logs:read", "comment": "Read logs" },
      { "name": "storage:buckets:read", "comment": "Read bucket data" },
      { "name": "smartscape:smartscape-nodes:read", "comment": "Read smartscape topology" } 
    ]
  }
}
